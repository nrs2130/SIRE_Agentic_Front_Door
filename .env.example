# ============================================================================
#  SIRE Voice Agent — Environment Configuration
# ============================================================================
#  Copy this file to .env and fill in your values:
#
#      cp .env.example .env       # Linux/macOS
#      copy .env.example .env     # Windows
#
# ============================================================================

# --- Azure AI Foundry / VoiceLive (Required) ---------------------------------
# Endpoint of your Azure AI Foundry resource
AZURE_VOICELIVE_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/

# API key (leave blank to use Entra ID / AzureCliCredential instead)
AZURE_VOICELIVE_API_KEY=

# Set to "true" to use AzureCliCredential (Entra ID) instead of API key
AZURE_VOICELIVE_USE_TOKEN=true

# Realtime model deployment name
AZURE_VOICELIVE_MODEL=gpt-realtime

# Voice for TTS output (Azure Neural Voice)
AZURE_VOICELIVE_VOICE=en-US-Ava:DragonHDLatestNeural

# --- Audio Devices (Optional) ------------------------------------------------
# Set specific device indices for microphone and speaker.
# Leave blank to use OS defaults (recommended).
# To list available devices, run:
#   python -c "import pyaudio; p=pyaudio.PyAudio(); [print(f'{i}: {p.get_device_info_by_index(i)[\"name\"]}') for i in range(p.get_device_count())]; p.terminate()"
AUDIO_INPUT_DEVICE_INDEX=
AUDIO_OUTPUT_DEVICE_INDEX=

# --- Azure AI Search (Required) ----------------------------------------------
# Your Azure AI Search service endpoint
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net

# Admin or query API key
AZURE_SEARCH_API_KEY=<your-search-api-key>

# Index names (defaults match the SIRE index schema)
AZURE_SEARCH_GROUP_INDEX=group-slot-mapping-index
AZURE_SEARCH_USER_INDEX=user-slot-mapping-index
AZURE_SEARCH_API_VERSION=2024-07-01

# --- Microsoft Foundry (Optional locally) ------------------------------------
# The orchestrator can run against mock MCP tools with no live project, so these
# are only required when deploying/using Foundry hosted agents + Foundry IQ.
# Project endpoint, e.g. https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=
# Model deployment name in the Foundry project (realtime/chat model)
FOUNDRY_MODEL_NAME=gpt-realtime
# Name of the hosted agent to bind (used by Voice Live agent-mode; optional)
FOUNDRY_AGENT_NAME=
# Set to "false" to use an API key path instead of Entra ID for Foundry
FOUNDRY_USE_TOKEN=true

# --- Orchestrator latency budgets (milliseconds, Optional) -------------------
# Soft timeouts per node; on breach the node emits a "still working on X" cue.
# Defaults mirror docs/01-architecture.md §4 — leave blank to use them.
BUDGET_SPOKEN_ACK_MS=300
BUDGET_ROUTER_MS=10
BUDGET_COMMS_TOOL_MS=800
BUDGET_LABS_TOOL_MS=2000
BUDGET_KNOWLEDGE_MS=1000
BUDGET_PATIENT_CONTEXT_MS=700

# --- Telemetry / OpenTelemetry (Optional) ------------------------------------
# Service name tagged on every span.
OTEL_SERVICE_NAME=nightingale
# Application Insights connection string (feeds the Foundry Control Plane).
# Leave blank to skip Azure Monitor export.
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Set to "true" to also print spans to the console (handy for local demos).
OTEL_CONSOLE_EXPORT=false

# --- L4 MCP tools (mock adapters + latency simulation, Optional) -------------
# Flip a tool from its demo mock to the real Vocera Engage adapter (no code change).
TOOLS_USE_REAL_ADAPTER=false
# Mock latency: base delay + random jitter (milliseconds) so latency is demoable.
TOOLS_MOCK_LATENCY_MS=250
TOOLS_MOCK_JITTER_MS=150
# Hard timeout per tool call (milliseconds); a slow adapter returns a typed timeout.
TOOLS_TIMEOUT_MS=3000
